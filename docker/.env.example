# Epic account email (2FA must be disabled)
EPIC_EMAIL=

# Epic account password (2FA must be disabled)
EPIC_PASSWORD=

# Multiple accounts (optional). JSON array; takes precedence over EPIC_EMAIL/EPIC_PASSWORD.
# Each account gets its own persistent browser profile and is processed sequentially.
# Add an optional per-account "proxy" to give each account its own exit IP.
# EPIC_ACCOUNTS=[{"email":"a@example.com","password":"pass1","proxy":"socks5://user:pass@host:1080"},{"email":"b@example.com","password":"pass2"}]

# Default proxy for accounts without their own "proxy" (http/socks5, optional)
# When set, Camoufox spoofs timezone/locale/geolocation to match the proxy IP (geoip)
# EPIC_PROXY=http://user:pass@host:port

# Run once and exit (false), or keep running on a schedule after the first run (true)
# Default: true
ENABLE_APSCHEDULER=true

# Cron expression for recurring runs (when ENABLE_APSCHEDULER=true).
# Five fields: minute hour day month day-of-week. Day-of-week accepts names
# (mon..sun), which avoids ambiguity, e.g. "0 18 * * thu" = Thursday 18:00.
# Default: 30 12 * * *  (daily at 12:30)
CRON_SCHEDULE=30 12 * * *

# Timezone for the schedule and log timestamps (IANA name, e.g. Europe/Kyiv, UTC)
# Default: UTC
SCHEDULE_TIMEZONE=UTC

# Telegram notifications (optional): alerts when a game is claimed or a run fails.
# Bot token from @BotFather; chat id e.g. from @userinfobot. Unset = notifications off.
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# TELEGRAM_CHAT_ID=123456789

# Disable bezier-curve trajectory simulation and rely on Camoufox's native behaviour
# Default: true
DISABLE_BEZIER_TRAJECTORY=true

# Create API Key https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# When your local network is poor, increase this value appropriately [unit: second]
# Default: 120
EXECUTION_TIMEOUT=120

# When your local network is poor, increase this value appropriately [unit: second]
# Default: 30
RESPONSE_TIMEOUT=30

# Re-execute the challenge when it fails
# Default: true
RETRY_ON_FAILURE=true

# When your local network is poor, increase this value appropriately [unit: millisecond]
# Default: 1500
WAIT_FOR_CHALLENGE_VIEW_TO_RENDER_MS=1500

# Whether to enable constraint encoding
# Default: true
CONSTRAINT_RESPONSE_SCHEMA=true

# For the challenge classification task
# Used as last resort when HSW decoding fails.
# Default: gemini-2.5-flash
CHALLENGE_CLASSIFIER_MODEL=gemini-2.5-flash

# NOTE: gemini-2.5-pro is NOT available on the free Gemini tier (quota = 0).
# These default to flash so a free GEMINI_API_KEY works out of the box.
# If you have a paid/billed key you may switch them to gemini-2.5-pro for higher
# captcha-solving accuracy.

# For the challenge type: `image_label_binary`
IMAGE_CLASSIFIER_MODEL=gemini-2.5-flash

# For the challenge type: `image_label_area_select` (single/multi)
SPATIAL_POINT_REASONER_MODEL=gemini-2.5-flash

# For the challenge type: `image_drag_drop` (single/multi)
SPATIAL_PATH_REASONER_MODEL=gemini-2.5-flash

# How many tokens should the thinking budget be?
# Default: 970
IMAGE_CLASSIFIER_THINKING_BUDGET=970

# How many tokens should the thinking budget be?
# Default: 1387
SPATIAL_POINT_THINKING_BUDGET=1387

# How many tokens should the thinking budget be?
# Default: 1652
SPATIAL_PATH_THINKING_BUDGET=1652
